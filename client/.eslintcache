ct';\r\n\r\nimport photo from '../style/avatar.png';\r\nimport dsBtn from '../style/ds.png';\r\nimport sdBtn from '../style/sd.png';\r\nimport cvBtn from '../style/cv.png';\r\nimport atBtn from '../style/at.png';\r\nimport { withRouter } from 'react-router-dom';\r\nimport axios from 'axios';\r\n\r\nconst Home = ({ history, pageTitle, setPageTitle }: any) => {\r\n\r\n    useEffect(() => {\r\n        setPageTitle('home')\r\n\r\n        return () => {\r\n            setPageTitle('')\r\n        }\r\n    }, [setPageTitle])\r\n    \r\n    const [repos, setRepos] = useState([])\r\n    useEffect(() => {\r\n        const getRepos = async() => {\r\n            try {\r\n                const res = await axios.get('https://api.github.com/users/Aragor70/repos')\r\n\r\n                setRepos(res.data)\r\n            } catch (err) {\r\n                console.log(err.message)\r\n            }\r\n            \r\n        }\r\n        getRepos()\r\n\r\n        return () => {\r\n            setRepos([])\r\n        }\r\n\r\n    }, [])\r\n\r\n    console.log(repos)\r\n\r\n    return (\r\n        <div className=\"home-content\">\r\n\r\n\r\n            <div className=\"navi-buttons\">\r\n                <div className=\"navi-button sd\" onClick={e=> history.push('/software_development')}>\r\n                <img src={sdBtn} alt=\"software_development\" />\r\n                <span>software development</span>\r\n                </div>\r\n                <div className=\"navi-button ds\" onClick={e=> history.push('/data_science')}>\r\n                <img src={dsBtn} alt=\"data_science\" />\r\n                <span>data science</span>\r\n                </div>\r\n                <div className=\"navi-button cv\" onClick={e=> history.push('/curriculum_vitae')}>\r\n                <img src={cvBtn} alt=\"curriculum_vitae\" />\r\n                <span>curriculum vitae</span>\r\n                </div>\r\n                <div className=\"navi-button at\" onClick={e=> history.push('/contact_mikolaj')}>\r\n                <img src={atBtn} alt=\"contact_mikolaj\" />\r\n                <span>contact</span>\r\n                </div>\r\n            </div>\r\n            <div className=\"avatar\">\r\n                <img src={photo} />\r\n                <span>Mikołaj<span>Prus</span></span>\r\n            </div>\r\n            \r\n            <div className=\"section-content\">\r\n                \r\n                {\r\n                    repos && repos.map((repo: any) => <p>{repo.name} </p>)\r\n                }\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\nexport default withRouter(Home);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Header.tsx",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\SD.tsx",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\DS.tsx",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\AT.tsx",["50"],"import React, { Fragment, useEffect } from 'react';\r\n\r\nimport imgEngineers from '../style/icons/engineers.png';\r\n\r\nimport { withRouter } from 'react-router-dom';\r\n\r\nconst AT = ({ location, pageTitle, setPageTitle, match }: any) => {\r\n\r\n    useEffect(() => {\r\n        setPageTitle('contact')\r\n\r\n        return () => {\r\n            setPageTitle('')\r\n        }\r\n    }, [setPageTitle])\r\n\r\n    return (\r\n        <Fragment>\r\n            <div className=\"section-content\">\r\n                <div className=\"params\">\r\n                \r\n                <p style={{ display: 'flex', justifyContent: \"center\" }}><img src={imgEngineers} /></p>\r\n\r\n                <p>Text me</p>\r\n                    mikey.prus@gmail.com\r\n                \r\n                <p>in : www.linkedin.com/in/mikolaj-prus</p>\r\n                <p>hr : www.hackerrank.com/mikey_prus</p>\r\n                    \r\n                \r\n\r\n                </div>\r\n            </div>\r\n        </Fragment>\r\n            \r\n    );\r\n}\r\nexport default withRouter(AT);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\CV.tsx",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Project.tsx",[],{"ruleId":"51","severity":1,"message":"52","line":1,"column":17,"nodeType":"53","messageId":"54","endLine":1,"endColumn":26},{"ruleId":"55","replacedBy":"56"},{"ruleId":"57","replacedBy":"58"},{"ruleId":"59","severity":1,"message":"60","line":66,"column":17,"nodeType":"61","endLine":66,"endColumn":36},{"ruleId":"59","severity":1,"message":"60","line":22,"column":74,"nodeType":"61","endLine":22,"endColumn":100},"@typescript-eslint/no-unused-vars","'useEffect' is defined but never used.","Identifier","unusedVar","no-native-reassign",["62"],"no-negated-in-lhs",["63"],"jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","no-global-assign","no-unsafe-negation"]