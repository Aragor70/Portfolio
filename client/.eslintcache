setPageTitle] = useState('')\r\n\r\n  return (\r\n    <Fragment>\r\n      <div className=\"shield\">\r\n        \r\n        <header className=\"header-content\">\r\n\r\n          <Header pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n        \r\n        </header>\r\n\r\n        \r\n        <main className=\"output\">\r\n          <Switch>\r\n            <Route exact path=\"/\">\r\n              <Home pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n            </Route>\r\n          \r\n              <Route exact path=\"/software_development\">\r\n                <SD pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/data_science\">\r\n                <DS pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/curriculum_vitae\">\r\n                <CV pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/contact_mikolaj\">\r\n                <AT pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n\r\n            \r\n          </Switch>\r\n\r\n        </main>\r\n          \r\n      </div>\r\n    </Fragment>\r\n  );\r\n}\r\nexport default withRouter(App);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Home.tsx",["47","48"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Header.tsx",["49","50","51","52","53","54"],"import React, { Fragment } from 'react';\r\n\r\nimport leftArrow from '../style/left-arrow.png';\r\nimport homeBtn from '../style/home.png';\r\n\r\nimport dsBtn from '../style/ds.png';\r\nimport sdBtn from '../style/sd.png';\r\nimport cvBtn from '../style/cv.png';\r\nimport atBtn from '../style/at.png';\r\n\r\n\r\nimport { withRouter } from 'react-router-dom';\r\n\r\nconst Header = ({ location: { pathname}, pageTitle, match, history }: any) => {\r\n\r\n    // <img src={leftArrow} style={{ width: \"55px\", marginRight: '7.5px' }}  />\r\n\r\n    return (\r\n        <Fragment>\r\n            <div className=\"page-title\">\r\n            <p>\r\n                {\r\n                    pathname === \"/\" ? null : <Fragment>\r\n                        <img src={leftArrow} style={{ width: \"55px\", marginRight: '7.5px' }} onClick={e=> history.goBack()}  />\r\n                        \r\n                        {\r\n                            pathname === '/software_development' && <img src={sdBtn} style={{ width: \"35px\" , marginRight: '7.5px'}} />\r\n                        }\r\n                        {\r\n                            pathname === '/data_science' && <img src={dsBtn} style={{ width: \"35px\" , marginRight: '7.5px'}} />\r\n                        }\r\n                        {\r\n                            pathname === '/curriculum_vitae' && <img src={cvBtn} style={{ width: \"35px\" , marginRight: '7.5px'}} />\r\n                        }\r\n                        {\r\n                            pathname === '/contact_mikolaj' && <img src={atBtn} style={{ width: \"35px\" , marginRight: '7.5px'}} onClick={e=> history.push('/')} />\r\n                        }\r\n                    </Fragment>\r\n                }\r\n                <span>{pageTitle}</span>\r\n            </p>\r\n                <hr />\r\n            </div>\r\n        </Fragment>\r\n            \r\n    );\r\n}\r\nexport default withRouter(Header);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\SD.tsx",["55","56","57","58","59","60","61","62","63","64","65","66","67","68","69","70","71","72","73","74","75","76","77","78","79","80","81","82"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\DS.tsx",["83"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\AT.tsx",["84"],"import React, { Fragment, useEffect } from 'react';\r\n\r\n\r\nimport { withRouter } from 'react-router-dom';\r\n\r\nconst AT = ({ location, pageTitle, setPageTitle, match }: any) => {\r\n\r\n    useEffect(() => {\r\n        setPageTitle('contact')\r\n    }, [])\r\n\r\n    return (\r\n        <Fragment>\r\n            contact\r\n        </Fragment>\r\n            \r\n    );\r\n}\r\nexport default withRouter(AT);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\CV.tsx",["85"],{"ruleId":"86","severity":1,"message":"87","line":1,"column":17,"nodeType":"88","messageId":"89","endLine":1,"endColumn":26},{"ruleId":"90","replacedBy":"91"},{"ruleId":"92","replacedBy":"93"},{"ruleId":"86","severity":1,"message":"87","line":1,"column":27,"nodeType":"88","messageId":"89","endLine":1,"endColumn":36},{"ruleId":"94","severity":1,"message":"95","line":14,"column":8,"nodeType":"96","endLine":14,"endColumn":10,"suggestions":"97"},{"ruleId":"98","severity":1,"message":"99","line":39,"column":17,"nodeType":"100","endLine":39,"endColumn":36},{"ruleId":"86","severity":1,"message":"101","line":4,"column":8,"nodeType":"88","messageId":"89","endLine":4,"endColumn":15},{"ruleId":"98","severity":1,"message":"99","line":24,"column":25,"nodeType":"100","endLine":24,"endColumn":128},{"ruleId":"98","severity":1,"message":"99","line":27,"column":69,"nodeType":"100","endLine":27,"endColumn":136},{"ruleId":"98","severity":1,"message":"99","line":30,"column":61,"nodeType":"100","endLine":30,"endColumn":128},{"ruleId":"98","severity":1,"message":"99","line":33,"column":65,"nodeType":"100","endLine":33,"endColumn":132},{"ruleId":"98","severity":1,"message":"99","line":36,"column":64,"nodeType":"100","endLine":36,"endColumn":163},{"ruleId":"86","severity":1,"message":"102","line":3,"column":8,"nodeType":"88","messageId":"89","endLine":3,"endColumn":11},{"ruleId":"86","severity":1,"message":"103","line":7,"column":8,"nodeType":"88","messageId":"89","endLine":7,"endColumn":17},{"ruleId":"86","severity":1,"message":"104","line":9,"column":8,"nodeType":"88","messageId":"89","endLine":9,"endColumn":15},{"ruleId":"86","severity":1,"mes