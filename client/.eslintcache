rningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"33","messages":"34","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"35","usedDeprecatedRules":"25"},{"filePath":"36","messages":"37","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"38","messages":"39","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"25"},{"filePath":"40","messages":"41","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"42","usedDeprecatedRules":"25"},{"filePath":"43","messages":"44","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"25"},{"filePath":"45","messages":"46","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"47","usedDeprecatedRules":"25"},"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\index.tsx",["48"],"import React, { useEffect } from 'react';\nimport ReactDOM from 'react-dom';\nimport { BrowserRouter as Router } from 'react-router-dom';\nimport App from './App';\nimport reportWebVitals from './reportWebVitals';\nimport './style/style.css';\nimport './style/front.css';\nimport './style/header.css';\nimport './style/section.css';\n\nReactDOM.render(\n  <React.StrictMode>\n      <Router>\n        <App />\n      </Router>\n  </React.StrictMode>, document.getElementById('root')\n);\n\n// If you want to start measuring performance in your app, pass a function\n// to log results (for example: reportWebVitals(console.log))\n// or send to an analytics endpoint. Learn more: https://bit.ly/CRA-vitals\nreportWebVitals();\n",["49","50"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\reportWebVitals.ts",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\App.tsx",["51","52"],"import React, { Fragment, useEffect, useState } from 'react';\r\n\r\n\r\nimport { Route, Switch, withRouter } from 'react-router-dom';\r\nimport AT from './interface/AT';\r\nimport CV from './interface/CV';\r\nimport DS from './interface/DS';\r\nimport Header from './interface/Header';\r\nimport Home from './interface/Home';\r\nimport Project from './interface/Project';\r\nimport SD from './interface/SD';\r\n\r\nconst App = ({ history }: any) => {\r\n\r\n  const [pageTitle, setPageTitle] = useState('')\r\n\r\n  return (\r\n    <Fragment>\r\n      <div className=\"shield\">\r\n        \r\n        <header className=\"header-content\">\r\n\r\n          <Header pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n        \r\n        </header>\r\n\r\n        \r\n        <main className=\"output\">\r\n          <Switch>\r\n            <Route exact path=\"/\">\r\n              <Home pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n            </Route>\r\n          \r\n              <Route path=\"/software_development\">\r\n                <SD pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/data_science\">\r\n                <DS pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/curriculum_vitae\">\r\n                <CV pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/contact_mikolaj\">\r\n                <AT pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n\r\n            \r\n          </Switch>\r\n\r\n        </main>\r\n          \r\n      </div>\r\n    </Fragment>\r\n  );\r\n}\r\nexport default withRouter(App);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Home.tsx",["53"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Header.tsx",["54"],"import React, { Fragment } from 'react';\r\n\r\nimport leftArrow from '../style/left-arrow.png';\r\nimport homeBtn from '../style/home.png';\r\n\r\nimport dsBtn from '../style/ds.png';\r\nimport sdBtn from '../style/sd.png';\r\nimport cvBtn from '../style/cv.png';\r\nimport atBtn from '../style/at.png';\r\n\r\n\r\nimport { withRouter } from 'react-router-dom';\r\n\r\nconst Header = ({ location: { pathname}, pageTitle, match, history }: any) => {\r\n\r\n    // <img src={leftArrow} style={{ width: \"55px\", marginRight: '7.5px' }}  />\r\n\r\n    return (\r\n        <Fragment>\r\n            <div className=\"page-title\">\r\n            <p>\r\n                {\r\n                    pathname === \"/\" ? null : <Fragment>\r\n                        <img src={leftArrow} style={{ width: \"35px\", marginRight: '7.5px' }} className=\"btn\" onClick={e=> history.goBack()} alt=\"leftArrow\"  />\r\n                        \r\n                        {\r\n                            pathname.split('/')[1] === 'software_development' && <img src={sdBtn} style={{ width: \"35px\" , marginRight: '7.5px'}} alt=\"SD\" />\r\n                        }\r\n                        {\r\n                            pathname.split('/')[1] === 'data_science' && <img src={dsBtn} style={{ width: \"35px\" , marginRight: '7.5px'}} alt=\"DS\" />\r\n                        }\r\n                        {\r\n                            pathname.split('/')[1] === 'curriculum_vitae' && <img src={cvBtn} style={{ width: \"35px\" , marginRight: '7.5px'}} alt=\"CV\" />\r\n                        }\r\n                        {\r\n                            pathname.split('/')[1] === 'contact_mikolaj' && <img src={atBtn} style={{ width: \"35px\" , marginRight: '7.5px'}} onClick={e=> history.push('/')} alt=\"AT\" />\r\n                        }\r\n                    </Fragment>\r\n                }\r\n                <span>{pageTitle}</span>\r\n            </p>\r\n                <hr />\r\n            </div>\r\n        </Fragment>\r\n            \r\n    );\r\n}\r\nexport default withRouter(Header);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\SD.tsx",["55","56","57"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\DS.tsx",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\AT.tsx",["58"],"import React, { Fragment, useEffect } from 'react';\r\n\r\nimport imgEngineers from '../style/icons/engineers.png';\r\n\r\nimport { withRouter } from 'react-router-dom';\r\n\r\nconst AT = ({ location, pageTitle, setPageTitle, match }: any) => {\r\n\r\n    useEffect(() => {\r\n        setPageTitle('contact')\r\n\r\n        return () => {\r\n            setPageTitle('')\r\n        }\r\n    }, [setPageTitle])\r\n\r\n    return (\r\n        <Fragment>\r\n            <div className=\"section-content\">\r\n                <div className=\"params\">\r\n                \r\n                <p style={{ display: 'flex', justifyContent: \"center\" }}><img src={imgEngineers} /></p>\r\n\r\n                <p>Text me</p>\r\n                    mikey.prus@gmail.com\r\n                \r\n                <p>in : www.linkedin.com/in/mikolaj-prus</p>\r\n                <p>hr : www.hackerrank.com/mikey_prus</p>\r\n                    \r\n                \r\n\r\n                </div>\r\n            </div>\r\n        </Fragment>\r\n            \r\n    );\r\n}\r\nexport default withRouter(AT);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\CV.tsx",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Project.tsx",["59"],"import React, { Fragment, useEffect } from 'react';\r\nimport { withRouter } from 'react-router-dom';\r\n\r\n\r\n\r\n\r\nconst Project = ({ name, title }: any) => {\r\n\r\n    \r\n\r\n    return (\r\n        <Fragment>\r\n            <div className=\"params\">\r\n\r\n                <h1>{ name }</h1> \r\n                \r\n                <p><span>{ title }</span></p>\r\n\r\n\r\n\r\n            </div>\r\n        </Fragment>\r\n    );\r\n}\r\nexport default withRouter(Project);",{"ruleId":"60","severity":1,"message":"61","line":1,"column":17,"nodeType":"62","messageId":"63","endLine":1,"endColumn":26},{"ruleId":"64","replacedBy":"65"},{"ruleId":"66","replacedBy":"67"},{"ruleId":"60","severity":1,"message":"61","line":1,"column":27,"nodeType":"62","messageId":"63","endLine":1,"endColumn":36},{"ruleId":"60","severity":1,"message":"68","line":10,"column":8,"nodeType":"62","messageId":"63","endLine":10,"endColumn":15},{"ruleId":"69","severity":1,"message":"70","line":66,"column":17,"nodeType":"71","endLine":66,"endColumn":36},{"ruleId":"60","severity":1,"message":"72","line":4,"column":8,"nodeType":"62","messageId":"63","endLine":4,"endColumn":15},{"ruleId":"60","severity":1,"message":"73","line":3,"column":8,"nodeType":"62","messageId":"63","endLine":3,"endColumn":11},{"ruleId":"60","severity":1,"message":"74","line":9,"column":8,"nodeType":"62","messageId":"63","endLine":9,"endColumn":15},{"ruleId":"60","severity":1,"message":"75","line":27,"column":54,"nodeType":"62","messageId":"63","endLine":27,"endColumn":60},{"ruleId":"69","severity":1,"message":"70","line":22,"column":74,"nodeType":"71","endLine":22,"endColumn":100},{"ruleId":"60","severity":1,"message":"61","line":1,"column":27,"nodeType":"62","messageId":"63","endLine":1,"endColumn":36},"@typescript-eslint/no-unused-vars","'useEffect' is defined but never used.","Identifier","unusedVar","no-native-reassign",["76"],"no-negated-in-lhs",["77"],"'Project' is defined but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","'homeBtn' is defined but never used.","'pht' is defined but never used.","'imgHtml' is defined but never used.","'Router' is defined but never used.","no-global-assign","no-unsafe-negation"]