\">\r\n        \r\n        <header className=\"header-content\">\r\n\r\n          <Header pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n        \r\n        </header>\r\n\r\n        \r\n        <main className=\"output\">\r\n          <Switch>\r\n            <Route exact path=\"/\">\r\n              <Home pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n            </Route>\r\n          \r\n              <Route exact path=\"/software_development\">\r\n                <SD pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/data_science\">\r\n                <DS pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/curriculum_vitae\">\r\n                <CV pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n              <Route exact path=\"/contact_mikolaj\">\r\n                <AT pageTitle={pageTitle} setPageTitle={setPageTitle} />\r\n              </Route>\r\n\r\n            \r\n          </Switch>\r\n\r\n        </main>\r\n          \r\n      </div>\r\n    </Fragment>\r\n  );\r\n}\r\nexport default withRouter(App);","C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Home.tsx",["45"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\Header.tsx",["46"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\SD.tsx",["47","48"],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\DS.tsx",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\AT.tsx",[],"C:\\Users\\Nicolai\\Documents\\Portfolio\\client\\src\\interface\\CV.tsx",[],{"ruleId":"49","severity":1,"message":"50","line":1,"column":17,"nodeType":"51","messageId":"52","endLine":1,"endColumn":26},{"ruleId":"53","replacedBy":"54"},{"ruleId":"55","replacedBy":"56"},{"ruleId":"49","severity":1,"message":"50","line":1,"column":27,"nodeType":"51","messageId":"52","endLine"